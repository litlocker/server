{
  "name": "server",
  "version": "1.0.0",
  "description": "Code for the server/api that handles all state.",
  "author": "Safwan Parkar",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.js",
    "start": "node --env-file=.env src/index.js",
    "start:debug": "node --env-file=.env --nolazy --inspect-brk=9229 src/index.js",
    "migrate:create": "node-pg-migrate create -m src/adapters/persistence/postgres/migrations/files",
    "migrate:up": "node --env-file=.env ./src/adapters/persistence/postgres/migrations/cli.js up",
    "migrate:down": "node --env-file=.env ./src/adapters/persistence/postgres/migrations/cli.js down",
    "lint:base": "oxlint",
    "lint:check": "pnpm run lint:base",
    "lint:fix": "pnpm run lint:base --fix",
    "lint:staged": "lint-staged",
    "lint:commit": "commitlint --edit",
    "lint:ts": "tsc --noEmit -p jsconfig.json",
    "fmt:base": "oxfmt",
    "fmt:check": "pnpm run fmt:base --check",
    "fmt:fix": "pnpm run fmt:base",
    "test:base": "vitest run .",
    "test:unit": "pnpm run test:base --config vitest.config.unit.js",
    "test:integration": "pnpm run test:base --config vitest.config.integration.js",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/oidc-auth": "^1.8.1",
    "@scalar/hono-api-reference": "^0.10.4",
    "ajv": "^8.18.0",
    "hono": "^4.12.8",
    "hono-rate-limiter": "^0.5.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": "^24"
  },
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.32.1"
  },
  "packageManager": "pnpm@10.32.1"
}
