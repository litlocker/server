LOGGER__DEBUG_LOGS_ENABLED=true

SERVER__HTTP__ADDRESS=http://localhost:3000
SERVER__HTTP__TIMEOUT_MS=9000
SERVER__HTTP__PORT=3000

STORAGE__PATHS__LIBRARY=./data/library
STORAGE__PATHS__IMPORTS=./data/imports
STORAGE__PATHS__COVERS=./data/covers

IMPORTS__MAX_FILE_SIZE_IN_BYTES=100000000
IMPORTS__ALLOWED_FILE_EXTENSIONS=epub,pdf,cbz,cbr
IMPORTS__DUPLICATE_CHECK_ENABLED=true

AUTH__ENABLED=false
AUTH__BOOTSTRAP_ADMIN_EMAIL=
AUTH__BOOTSTRAP_ADMIN_PASSWORD=
AUTH__SESSION_TTL_MS=86400000
AUTH__SESSION_COOKIE_NAME=litlocker-session
AUTH__SESSION_COOKIE_SECURE=true
AUTH__OIDC__ISSUER_URL=
AUTH__OIDC__CLIENT_ID=
AUTH__OIDC__CLIENT_SECRET=
AUTH__OIDC__REDIRECT_URL=
AUTH__OIDC__POST_LOGOUT_REDIRECT_URL=
AUTH__OIDC__SCOPES=openid,profile,email
AUTH__OIDC__REQUIRE_PKCE=true
AUTH__OIDC__DISCOVERY_TIMEOUT_MS=5000

METADATA_PROVIDERS__ENABLED_PROVIDERS=open-library
METADATA_PROVIDERS__LOOKUP_TIMEOUT_MS=5000
METADATA_PROVIDERS__DEFAULT_LANGUAGE=en
